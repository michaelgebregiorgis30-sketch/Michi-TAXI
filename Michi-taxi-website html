<script>
  const now = new Date();
  now.setMinutes(now.getMinutes() - now.getTimezoneOffset());
  const dtInput = document.getElementById('b-datetime');
  if (dtInput) dtInput.min = now.toISOString().slice(0,16);

  function submitBooking() {
    const car     = document.getElementById('b-car').value;
    const name    = document.getElementById('b-name').value.trim();
    const dt      = document.getElementById('b-datetime').value;
    const pickup  = document.getElementById('b-pickup').value.trim();
    const dest    = document.getElementById('b-dest').value.trim();
    const persons = document.getElementById('b-persons').value;
    const phone   = document.getElementById('b-phone').value.trim();
    const notes   = document.getElementById('b-notes').value.trim();

    if (!name || !dt || !pickup || !dest) {
      alert('Bitte füllen Sie Name, Datum, Abholort und Zielort aus.');
      return;
    }

    const d = new Date(dt);
    const formatted = d.toLocaleString('de-CH', {
      weekday:'long', day:'2-digit', month:'2-digit',
      year:'numeric', hour:'2-digit', minute:'2-digit'
    });

    const msg =
      `🚙 *MICHI TAXI – Buchungsanfrage*\n\n` +
      `🚗 *Fahrzeug:* ${car}\n` +
      `👤 *Name:* ${name}\n` +
      `📅 *Datum & Zeit:* ${formatted}\n` +
      `📍 *Abholort:* ${pickup}\n` +
      `🏁 *Zielort:* ${dest}\n` +
      `👥 *Personen:* ${persons}\n` +
      (phone ? `📞 *Tel:* ${phone}\n` : '') +
      (notes ? `💬 *Bemerkungen:* ${notes}\n` : '') +
      `\nMit Gott sicher ans Ziel`;

    window.open(`https://wa.me/41763238832?text=${encodeURIComponent(msg)}`, '_blank');
  }
</script>
