<!-- SERVICES -->
<section class="services" id="services">
  <div class="section-label">Leistungen</div>
  <div class="section-title">Was ich<br><span>anbiete</span></div>
  <div class="services-grid">
    <div class="service-card">
      <span class="service-icon">✈️</span>
      <div class="service-title">Flughafen Transfers</div>
      <p class="service-desc">Zuverlässige Fahrten zum Flughafen Zürich und zurück. Pünktlich, stressfrei, mit Gepäckbegleitung.</p>
