<!DOCTYPE html>
<html lang="de">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Michi Taxi – Winterthur</title>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:ital,wght@0,300;0,400;0,500;0,700;1,300;1,400&display=swap" rel="stylesheet">
<style>
  :root {
    --blue:    #1a3a6b;
    --blue2:   #2a5298;
    --silver:  #c0c8d8;
    --black:   #0d0d0d;
    --dark:    #111827;
    --gray:    #1e2535;
    --light:   #f0f2f7;
    --white:   #ffffff;
  }

  *, *::before, *::after { margin:0; padding:0; box-sizing:border-box; }

  html { scroll-behavior: smooth; }

  body {
    background: var(--black);
    color: var(--white);
    font-family: 'DM Sans', sans-serif;
    overflow-x: hidden;
  }

  /* ── NAV ── */
  nav {
    position: fixed; top:0; left:0; width:100%; z-index:100;
    padding: 16px 32px;
    display: flex; align-items: center; justify-content: space-between;
    background: rgba(13,13,13,0.85);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(192,200,216,0.1);
  }

  .nav-logo {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 28px; letter-spacing: 3px;
    color: var(--white);
  }

  .nav-logo span { color: var(--silver); }

  .nav-links { display:flex; gap:28px; }
  .nav-links a {
    color: var(--silver); font-size: 13px;
    letter-spacing: 1.5px; text-decoration: none;
    text-transform: uppercase; opacity: 0.7;
    transition: opacity 0.2s;
  }
  .nav-links a:hover { opacity: 1; }

  .nav-cta {
    background: var(--blue2);
    color: #fff !important; opacity: 1 !important;
    padding: 8px 20px; border-radius: 6px;
  }

  /* ── HERO ── */
  .hero {
    min-height: 100vh;
    display: flex; flex-direction: column;
    justify-content: center; align-items: flex-start;
    padding: 120px 8vw 80px;
    position: relative; overflow: hidden;
  }

  .hero-bg {
    position: absolute; inset:0; z-index:0;
    background: linear-gradient(135deg, #0d0d0d 0%, #0a1628 50%, #0d1f45 100%);
  }

  .hero-grid {
    position: absolute; inset:0; z-index:0;
    background-image:
      linear-gradient(rgba(42,82,152,0.07) 1px, transparent 1px),
      linear-gradient(90deg, rgba(42,82,152,0.07) 1px, transparent 1px);
    background-size: 60px 60px;
  }

  .hero-glow {
    position: absolute; top:-20%; right:-10%;
    width: 600px; height: 600px;
    background: radial-gradient(circle, rgba(42,82,152,0.25) 0%, transparent 70%);
    z-index:0;
  }

  .hero-content { position: relative; z-index:1; max-width: 700px; }

  .hero-badge {
    display: inline-flex; align-items: center; gap:8px;
    background: rgba(42,82,152,0.2);
    border: 1px solid rgba(42,82,152,0.4);
    padding: 6px 16px; border-radius: 20px;
    font-size: 11px; letter-spacing: 2px; color: var(--silver);
    text-transform: uppercase; margin-bottom: 28px;
    animation: fadeDown 0.8s ease both;
  }

  .hero h1 {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(64px, 10vw, 120px);
    line-height: 0.88; letter-spacing: 2px;
    animation: fadeDown 0.8s 0.1s ease both;
  }

  .hero h1 span { color: var(--silver); }

  .hero-tagline {
    font-size: 18px; font-weight: 300;
    color: var(--silver); margin: 24px 0 40px;
    line-height: 1.6; max-width: 480px;
    animation: fadeDown 0.8s 0.2s ease both;
  }

  .hero-tagline em {
    font-style: italic; color: var(--white); font-weight: 400;
  }

  .hero-buttons {
    display: flex; gap: 16px; flex-wrap: wrap;
    animation: fadeDown 0.8s 0.3s ease both;
  }

  .btn-primary {
    background: var(--blue2); color: #fff;
    padding: 16px 32px; border-radius: 8px;
    font-size: 14px; font-weight: 500; letter-spacing: 1px;
    text-decoration: none; text-transform: uppercase;
    display: inline-flex; align-items: center; gap: 10px;
    transition: transform 0.2s, box-shadow 0.2s;
    box-shadow: 0 8px 32px rgba(42,82,152,0.4);
  }

  .btn-primary:hover {
    transform: translateY(-3px);
    box-shadow: 0 16px 48px rgba(42,82,152,0.5);
  }

  .btn-whatsapp {
    background: #25D366; color: #fff;
    padding: 16px 32px; border-radius: 8px;
    font-size: 14px; font-weight: 500; letter-spacing: 1px;
    text-decoration: none; text-transform: uppercase;
    display: inline-flex; align-items: center; gap: 10px;
    transition: transform 0.2s, box-shadow 0.2s;
    box-shadow: 0 8px 32px rgba(37,211,102,0.3);
  }

  .btn-whatsapp:hover {
    transform: translateY(-3px);
    box-shadow: 0 16px 48px rgba(37,211,102,0.4);
  }

  .hero-scroll {
    position: absolute; bottom: 40px; left: 50%;
    transform: translateX(-50%);
    display: flex; flex-direction: column; align-items: center; gap: 8px;
    color: var(--silver); font-size: 10px; letter-spacing: 2px;
    text-transform: uppercase; opacity: 0.5;
    animation: bounce 2s infinite;
  }

  @keyframes bounce {
    0%,100% { transform: translateX(-50%) translateY(0); }
    50% { transform: translateX(-50%) translateY(8px); }
  }

  /* ── STATS ── */
  .stats {
    background: var(--gray);
    border-top: 1px solid rgba(192,200,216,0.1);
    border-bottom: 1px solid rgba(192,200,216,0.1);
    padding: 48px 8vw;
    display: grid; grid-template-columns: repeat(4, 1fr);
    gap: 32px;
  }

  .stat { text-align: center; }
  .stat-num {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 52px; color: var(--silver);
    line-height: 1; letter-spacing: 2px;
  }
  .stat-label {
    font-size: 11px; color: #666;
    letter-spacing: 2px; text-transform: uppercase;
    margin-top: 4px;
  }

  /* ── SECTIONS ── */
  section { padding: 100px 8vw; }

  .section-label {
    font-size: 11px; letter-spacing: 4px;
    text-transform: uppercase; color: var(--blue2);
    margin-bottom: 16px;
  }

  .section-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(36px, 5vw, 60px);
    letter-spacing: 2px; line-height: 1;
    margin-bottom: 24px;
  }

  .section-title span { color: var(--silver); }

  /* ── ABOUT ── */
  .about { background: var(--dark); }

  .about-grid {
    display: grid; grid-template-columns: 1fr 1fr;
    gap: 80px; align-items: center; margin-top: 60px;
  }

  .about-text p {
    color: var(--silver); font-size: 16px;
    line-height: 1.8; font-weight: 300;
    margin-bottom: 20px;
  }

  .about-faith {
    background: rgba(42,82,152,0.1);
    border-left: 3px solid var(--blue2);
    padding: 20px 24px; border-radius: 0 8px 8px 0;
    margin-top: 24px;
  }

  .about-faith p {
    font-style: italic; font-size: 15px;
    color: var(--silver) !important; margin:0 !important;
  }

  .about-car {
    background: linear-gradient(135deg, var(--gray), var(--dark));
    border: 1px solid rgba(192,200,216,0.1);
    border-radius: 16px; padding: 48px;
    text-align: center; position: relative; overflow: hidden;
  }

  .about-car::before {
    content: '';
    position: absolute; inset:0;
    background: radial-gradient(circle at 50% 50%, rgba(42,82,152,0.15), transparent 70%);
  }

  .car-emoji { font-size: 96px; display:block; margin-bottom: 20px; }

  .car-specs {
    display: grid; grid-template-columns: 1fr 1fr;
    gap: 12px; margin-top: 24px;
  }

  .spec {
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(192,200,216,0.1);
    border-radius: 8px; padding: 12px 16px;
    text-align: left;
  }

  .spec-label { font-size: 10px; color: #555; letter-spacing: 1px; text-transform: uppercase; }
  .spec-value { font-size: 14px; color: var(--silver); font-weight: 500; margin-top: 2px; }

  /* ── SERVICES ── */
  .services { background: var(--black); }

  .services-grid {
    display: grid; grid-template-columns: repeat(3, 1fr);
    gap: 24px; margin-top: 60px;
  }

  .service-card {
    background: var(--gray);
    border: 1px solid rgba(192,200,216,0.08);
    border-radius: 16px; padding: 36px 28px;
    transition: transform 0.3s, border-color 0.3s;
  }

  .service-card:hover {
    transform: translateY(-6px);
    border-color: rgba(42,82,152,0.4);
  }

  .service-icon { font-size: 40px; margin-bottom: 20px; display:block; }
  .service-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 22px; letter-spacing: 2px;
    color: var(--silver); margin-bottom: 12px;
  }
  .service-desc { font-size: 14px; color: #666; line-height: 1.7; }

  /* ── PRICES ── */
  .prices { background: var(--dark); }

  .prices-grid {
    display: grid; grid-template-columns: repeat(3, 1fr);
    gap: 24px; margin-top: 60px;
  }

  .price-card {
    background: var(--gray);
    border: 1px solid rgba(192,200,216,0.08);
    border-radius: 16px; padding: 36px 28px;
    text-align: center;
  }

  .price-card.featured {
    border-color: var(--blue2);
    background: linear-gradient(135deg, var(--gray), rgba(42,82,152,0.15));
    position: relative;
  }

  .price-card.featured::before {
    content: 'BELIEBT';
    position: absolute; top:-12px; left:50%; transform:translateX(-50%);
    background: var(--blue2); color:#fff;
    font-size: 10px; letter-spacing: 2px; padding: 4px 14px;
    border-radius: 20px;
  }

  .price-route { font-size: 13px; color: #666; letter-spacing: 1px; margin-bottom: 16px; }
  .price-amount {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 48px; color: var(--silver); letter-spacing: 2px;
  }
  .price-amount span { font-size: 20px; }
  .price-desc { font-size: 13px; color: #555; margin-top: 12px; line-height: 1.6; }

  /* ── BOOKING ── */
  .booking { background: var(--black); }

  .booking-inner {
    display: grid; grid-template-columns: 1fr 1fr;
    gap: 80px; align-items: start; margin-top: 60px;
  }

  .booking-info h3 {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 28px; letter-spacing: 2px; color: var(--silver);
    margin-bottom: 16px;
  }

  .booking-info p { font-size: 15px; color: #666; line-height: 1.8; margin-bottom: 24px; }

  .contact-item {
    display: flex; align-items: center; gap: 14px;
    padding: 16px 0;
    border-bottom: 1px solid rgba(192,200,216,0.08);
  }

  .contact-icon { font-size: 22px; width: 36px; text-align: center; }
  .contact-label { font-size: 11px; color: #555; letter-spacing: 1px; text-transform: uppercase; }
  .contact-value { font-size: 16px; color: var(--silver); font-weight: 500; }

  .booking-form {
    background: var(--gray);
    border: 1px solid rgba(192,200,216,0.08);
    border-radius: 20px; padding: 40px;
  }

  .booking-form h3 {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 28px; letter-spacing: 2px;
    color: var(--silver); margin-bottom: 28px;
  }

  .form-group { margin-bottom: 18px; }

  label {
    display: block; font-size: 11px; letter-spacing: 1.5px;
    color: var(--blue2); text-transform: uppercase; margin-bottom: 8px;
  }

  input, textarea, select {
    width: 100%;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(192,200,216,0.12);
    border-radius: 10px; padding: 14px 16px;
    color: var(--white); font-family: 'DM Sans', sans-serif;
    font-size: 15px; outline: none;
    transition: border-color 0.2s, box-shadow 0.2s;
  }

  input:focus, textarea:focus, select:focus {
    border-color: var(--blue2);
    box-shadow: 0 0 0 3px rgba(42,82,152,0.15);
  }

  input[type="datetime-local"] { color-scheme: dark; }

  select option { background: var(--dark); }

  textarea { resize: none; height: 90px; }

  .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }

  .wa-submit {
    width: 100%; background: #25D366; color: #fff;
    border: none; border-radius: 12px; padding: 18px;
    font-family: 'Bebas Neue', sans-serif;
    font-size: 20px; letter-spacing: 2px;
    cursor: pointer; margin-top: 8px;
    display: flex; align-items: center; justify-content: center; gap: 10px;
    transition: transform 0.2s, box-shadow 0.2s;
    box-shadow: 0 8px 32px rgba(37,211,102,0.3);
  }

  .wa-submit:hover {
    transform: translateY(-2px);
    box-shadow: 0 14px 40px rgba(37,211,102,0.4);
  }

  /* ── FOOTER ── */
  footer {
    background: var(--dark);
    border-top: 1px solid rgba(192,200,216,0.08);
    padding: 48px 8vw;
    display: flex; justify-content: space-between; align-items: center;
    flex-wrap: wrap; gap: 24px;
  }

  .footer-brand {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 32px; letter-spacing: 3px; color: var(--silver);
  }

  .footer-faith {
    font-style: italic; font-size: 14px;
    color: #444; letter-spacing: 1px;
  }

  .footer-copy { font-size: 12px; color: #333; letter-spacing: 1px; }

  /* ── ANIMATIONS ── */
  @keyframes fadeDown {
    from { opacity: 0; transform: translateY(-20px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* ── RESPONSIVE ── */
  @media (max-width: 768px) {
    nav { padding: 14px 20px; }
    .nav-links { display: none; }
    .hero { padding: 100px 6vw 60px; }
    .stats { grid-template-columns: repeat(2,1fr); padding: 40px 6vw; }
    section { padding: 60px 6vw; }
    .about-grid, .booking-inner { grid-template-columns: 1fr; gap: 40px; }
    .services-grid, .prices-grid { grid-template-columns: 1fr; }
    .form-row { grid-template-columns: 1fr; }
    footer { flex-direction: column; text-align: center; padding: 36px 6vw; }
  }
</style>
</head>
